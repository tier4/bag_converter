#!/bin/bash

# Docker image tag
IMAGE_TAG="latest"

# Path to the bag_converter binary inside the container
BIN="/opt/drs/install/bag_converter/lib/bag_converter/bag_converter"

# Check if Docker is installed
if ! command -v docker >/dev/null 2>&1; then
    echo "Error: Docker is not installed. Please install Docker from https://docs.docker.com/engine/install/"
    exit 1
fi

# Check if bag_converter:${IMAGE_TAG} image exists
if ! docker image inspect bag_converter:${IMAGE_TAG} >/dev/null 2>&1; then
    echo "Error: Docker image 'bag_converter:${IMAGE_TAG}' not found. Please build it first by running: cd bag_converter/docker && ./build.sh"
    exit 1
fi

# Use -it when running in a TTY, -i otherwise
DOCKER_FLAGS="-i"
if [ -t 0 ]; then
    DOCKER_FLAGS="-it"
fi

# Detect deprecated subcommand usage
if [ "${1:-}" = "conv" ] || [ "${1:-}" = "merge" ]; then
    echo "Error: Subcommands 'conv' and 'merge' have been removed."
    echo ""
    echo "New usage:"
    echo "  bag_converter <input_bag> <output_bag> [options]"
    echo "  bag_converter <input_dir_0> [input_dir_1 ...] <output_dir> --merge [options]"
    echo ""
    echo "Run 'bag_converter --help' for details."
    exit 1
fi

# If no positional args or just --help/--version, pass directly to binary
if [ $# -eq 0 ] || [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ] || [ "${1:-}" = "--version" ] || [ "${1:-}" = "-v" ]; then
    docker run $DOCKER_FLAGS --rm \
        bag_converter:${IMAGE_TAG} \
        "$BIN" "$@"
    exit $?
fi

# --- Detect flags ---
HAS_MERGE=false
HAS_DELETE=false
for arg in "$@"; do
    case "$arg" in
    --merge) HAS_MERGE=true ;;
    --delete) HAS_DELETE=true ;;
    esac
done

# Helper: list of options that take a value argument
option_takes_value() {
    case "$1" in
    --min-range | --max-range | --point-type | --timescale-correction | --timescale-correction-ref | --base-frame | --tf-mode)
        return 0
        ;;
    *)
        return 1
        ;;
    esac
}

# --- Separate positional args from option args ---
POSITIONAL=()
OPTIONS=()
skip_next=false
for arg in "$@"; do
    if $skip_next; then
        OPTIONS+=("$arg")
        skip_next=false
        continue
    fi
    if [[ $arg == -* ]]; then
        OPTIONS+=("$arg")
        if option_takes_value "$arg"; then
            skip_next=true
        fi
    else
        POSITIONAL+=("$arg")
    fi
done

# --- Merge mode ---
if $HAS_MERGE; then
    if [ ${#POSITIONAL[@]} -lt 2 ]; then
        echo "Error: --merge requires at least one input directory and one output directory."
        exit 1
    fi

    # Last positional = output dir, rest = input dirs
    last_idx=$((${#POSITIONAL[@]} - 1))
    OUTPUT_ABS=$(realpath -m "${POSITIONAL[$last_idx]}")
    mkdir -p "$OUTPUT_ABS"

    # Mount input dirs as rw if --delete, ro otherwise
    INPUT_MOUNT_MODE="ro"
    if $HAS_DELETE; then
        INPUT_MOUNT_MODE="rw"
    fi

    DOCKER_VOLUMES=(-v "$OUTPUT_ABS":/output)
    CONTAINER_ARGS=()

    for ((i = 0; i < last_idx; i++)); do
        INPUT_ABS=$(realpath "${POSITIONAL[$i]}")
        DOCKER_VOLUMES+=(-v "$INPUT_ABS:/input/$i:$INPUT_MOUNT_MODE")
        CONTAINER_ARGS+=("/input/$i")
    done
    CONTAINER_ARGS+=(/output)

    docker run $DOCKER_FLAGS --rm \
        "${DOCKER_VOLUMES[@]}" \
        bag_converter:${IMAGE_TAG} \
        "$BIN" "${CONTAINER_ARGS[@]}" "${OPTIONS[@]}"
    exit $?
fi

# --- Directory mode ---
if [ ${#POSITIONAL[@]} -ge 2 ] && [ -d "${POSITIONAL[0]}" ]; then
    INPUT_ABS=$(realpath "${POSITIONAL[0]}")
    OUTPUT_ABS=$(realpath -m "${POSITIONAL[1]}")

    # Create output directory on host so Docker doesn't create it as root
    mkdir -p "$OUTPUT_ABS"

    # Mount input as rw if --delete, ro otherwise
    INPUT_MOUNT_MODE="ro"
    if $HAS_DELETE; then
        INPUT_MOUNT_MODE="rw"
    fi

    docker run $DOCKER_FLAGS --rm \
        -v "$INPUT_ABS":/input:$INPUT_MOUNT_MODE \
        -v "$OUTPUT_ABS":/output \
        bag_converter:${IMAGE_TAG} \
        "$BIN" /input /output "${OPTIONS[@]}"
    exit $?
fi

# --- Single file mode ---
if [ ${#POSITIONAL[@]} -ge 2 ]; then
    INPUT_PATH="${POSITIONAL[0]}"
    OUTPUT_PATH="${POSITIONAL[1]}"

    # Get absolute paths (use -m for output to allow non-existent paths)
    INPUT_ABS=$(realpath "$INPUT_PATH" 2>/dev/null || echo "$INPUT_PATH")
    OUTPUT_ABS=$(realpath -m "$OUTPUT_PATH" 2>/dev/null || echo "$OUTPUT_PATH")

    # Get directory paths for Docker volume mounting
    INPUT_DIR=$(dirname "$INPUT_ABS")
    OUTPUT_DIR=$(dirname "$OUTPUT_ABS")
    INPUT_FILE=$(basename "$INPUT_ABS")
    OUTPUT_FILE=$(basename "$OUTPUT_ABS")

    # Mount input dir as rw if --delete, ro otherwise
    INPUT_MOUNT_MODE="ro"
    if $HAS_DELETE; then
        INPUT_MOUNT_MODE="rw"
    fi

    docker run $DOCKER_FLAGS --rm \
        -v "$INPUT_DIR":/input:$INPUT_MOUNT_MODE \
        -v "$OUTPUT_DIR":/output \
        bag_converter:${IMAGE_TAG} \
        "$BIN" "/input/$INPUT_FILE" "/output/$OUTPUT_FILE" "${OPTIONS[@]}"
    exit $?
fi

# Fallback: not enough args — pass to binary to show usage
docker run $DOCKER_FLAGS --rm \
    bag_converter:${IMAGE_TAG} \
    "$BIN" "$@"
